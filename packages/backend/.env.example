# LLM
ANTHROPIC_API_KEY=

# Data integration
NEXLA_API_KEY=

# Publishing
TINYFISH_API_KEY=

# Memory + a2a
REDIS_URL=

# Wallet + settlement
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Voice
VAPI_API_KEY=
VAPI_PHONE_NUMBER=

# Guild
GUILD_WORKSPACE_ID=

# Chainguard
CHAINGUARD_PULL_TOKEN=

# InsForge + Ghost are obtained at runtime by the agent (no pre-set key)

# PCC
PCC_AGENT_PACKAGE_URL=https://capability.network/agent-package.json
PCC_CAPABILITY_BASE=https://capability.network

# Mode flags (set true to run without credentials)
MOCK_NEXLA=true
MOCK_TINYFISH=true
MOCK_INSFORGE=true
MOCK_GHOST=true
MOCK_REDIS=true
MOCK_CDP=true

PORT=3000
LOG_LEVEL=info
