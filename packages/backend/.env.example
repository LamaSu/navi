# LLM
ANTHROPIC_API_KEY=

# Data integration
NEXLA_API_KEY=

# Memory + a2a
REDIS_URL=

# Wallet + settlement
# Wallets are minted locally via viem (no CDP credentials required).
# CDP integration deferred to Wave 3 (gasless UX upgrade if needed).

# Voice
VAPI_API_KEY=
VAPI_PHONE_NUMBER=

# Guild
GUILD_WORKSPACE_ID=

# Chainguard
CHAINGUARD_PULL_TOKEN=

# InsForge + Ghost are obtained at runtime by the agent (no pre-set key)

# PCC
PCC_AGENT_PACKAGE_URL=https://capability.network/agent-package.json
PCC_CAPABILITY_BASE=https://capability.network
# PCC_BASE_URL takes precedence for the discovery client; defaults to PCC_CAPABILITY_BASE.
PCC_BASE_URL=
# Bearer token from /api/auth/provision — required for /api/dht/announce. Without it
# discovery still works (registration succeeds) but DHT announce is skipped.
PCC_API_KEY=

# Mode flags (set true to run without credentials)
MOCK_NEXLA=true
MOCK_INSFORGE=true
MOCK_GHOST=true
MOCK_REDIS=true
MOCK_CDP=true
MOCK_PCC_DISCOVERY=true
# MOCK_WEB_EXTRACT=true  # uncomment to skip camoufox+Claude in tests/dev

PORT=3000
LOG_LEVEL=info
